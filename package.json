{
    "name": "@cbnsndwch/ghl-sdk-monorepo",
    "description": "A base template for full stack HighLevel Marketplace apps",
    "version": "0.5.1",
    "license": "MIT",
    "private": true,
    "repository": "https://github.com/cbnsndwch/ghl-app",
    "author": {
        "name": "Sergio Leon",
        "url": "https://www.cbnsndwch.io"
    },
    "workspaces": {
        "packages": [
            "apps/*",
            "libs/*"
        ]
    },
    "scripts": {
        "postinstall": "turbo run build",
        "clean": "turbo run clean",
        "build": "turbo run build",
        "format": "turbo run format",
        "lint": "turbo run lint",
        "lint:fix": "turbo run lint:fix",
        "test": "turbo run test",
        "pub": "turbo run pub",
        "changeset": "changeset",
        "changeset:version": "changeset version",
        "changeset:publish": "changeset publish"
    },
    "devDependencies": {
        "@changesets/cli": "catalog:",
        "change-case": "catalog:",
        "glob": "catalog:",
        "globals": "catalog:",
        "http-server": "catalog:",
        "npm-check-updates": "catalog:",
        "oxc": "catalog:",
        "oxfmt": "catalog:",
        "oxlint": "catalog:",
        "turbo": "catalog:",
        "vite": "catalog:"
    },
    "packageManager": "pnpm@10.33.0"
}
