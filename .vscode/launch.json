{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug API",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "pnpm",
            "runtimeArgs": ["dev"],
            "skipFiles": ["<node_internals>/**", "**/node_modules/@nestjs/**"],
            "env": {
                "LOG_LEVEL": "VERBOSE"
            },
            "cwd": "${workspaceRoot}/apps/server",
            "console": "integratedTerminal"
        },
        {
            "name": "Start Web",
            "type": "node",
            "request": "launch",
            "skipFiles": ["<node_internals>/**"],
            "runtimeExecutable": "pnpm",
            "cwd": "${workspaceRoot}/apps/web",
            "runtimeArgs": ["start"]
        },
        {
            "name": "Debug Current File (ROOT)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "pnpm",
            "runtimeArgs": [
                "tsx",
                "${file}"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "cwd": "'${workspaceFolder}'",
        },
        {
            "name": "Debug Current File (CWD)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "pnpm",
            "runtimeArgs": [
                "tsx",
                "${file}"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "cwd": "${fileDirname}",
        }
    ]
}
