{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug API",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "pnpm",
            "runtimeArgs": [
                "dev"
            ],
            "skipFiles": [
                "<node_internals>/**",
                "**/node_modules/@nestjs/**"
            ],
            "env": {
                "LOG_LEVEL": "VERBOSE"
            },
            "cwd": "${workspaceRoot}/apps/server",
            "console": "integratedTerminal"
        },
        {
            "name": "Debug CLI",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "pnpm",
            "runtimeArgs": [
                "tsx",
                "${workspaceFolder}/apps/cli/src/index.ts",
                "logs"
                // "--help"
            ],
            "env": {
                "CONSOLA_LEVEL": "5"
            },
            "cwd": "${workspaceFolder}/apps/cli",
            "console": "integratedTerminal",
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": "Start Web",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeExecutable": "pnpm",
            "cwd": "${workspaceRoot}/apps/web",
            "runtimeArgs": [
                "start"
            ]
        },
        {
            "name": "Debug Current File (ROOT)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "pnpm",
            "runtimeArgs": [
                "tsx",
                "${file}"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "cwd": "'${workspaceFolder}'",
        },
        {
            "name": "Debug Current File (CWD)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "pnpm",
            "runtimeArgs": [
                "tsx",
                "${file}"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "cwd": "${fileDirname}",
        }
    ]
}