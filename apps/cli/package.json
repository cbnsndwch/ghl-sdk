{
    "name": "@cbnsndwch/ghl-cli",
    "description": "GHL Marketplace Developer CLI — scaffolding, local dev, webhook testing, and log streaming",
    "version": "0.5.2",
    "type": "module",
    "license": "MIT",
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "author": {
        "name": "cbnsndwch LLC",
        "url": "https://github.com/cbnsndwch"
    },
    "bin": {
        "ghl": "./dist/index.js"
    },
    "scripts": {
        "build": "tsup",
        "clean": "rm -rf dist",
        "dev": "tsup --watch",
        "format": "oxfmt --write src",
        "lint": "oxlint ./src",
        "lint:fix": "oxlint ./src --fix",
        "test": "vitest --run --passWithNoTests",
        "test:watch": "vitest"
    },
    "engines": {
        "node": ">=22"
    },
    "dependencies": {
        "@cbnsndwch/ghl-sdk": "workspace:*",
        "@cbnsndwch/ghl-sdk-core": "workspace:*",
        "@cbnsndwch/ghl-sdk-webhooks": "workspace:*",
        "@clack/prompts": "catalog:",
        "@sentry/node": "^10.46.0",
        "ci-info": "^4.4.0",
        "citty": "catalog:",
        "conf": "^15.1.0",
        "consola": "catalog:",
        "defu": "catalog:",
        "giget": "^3.2.0",
        "picocolors": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "@vitest/coverage-v8": "catalog:",
        "oxc": "catalog:",
        "oxfmt": "catalog:",
        "oxlint": "catalog:",
        "tsup": "catalog:",
        "tsx": "catalog:",
        "typescript": "catalog:",
        "vite": "catalog:",
        "vitest": "catalog:"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "main": "./dist/index.js"
}
