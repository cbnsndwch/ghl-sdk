{
    "files": [],
    "references": [
        {
            "path": "./tsconfig.node.json"
        },
        {
            "path": "./tsconfig.vite.json"
        }
    ],
    "compilerOptions": {
        "checkJs": true,
        "verbatimModuleSyntax": true,
        "experimentalDecorators": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "types": [
            "vitest",
            "./types"
        ],
        "paths": {
            "@/*": [
                "./app/*"
            ],
            "src/*": [
                "./src/*"
            ]
        }
    }
}