{
    "$schema": "https://json.schemastore.org/nest-cli",
    "collection": "@nestjs/schematics",
    "sourceRoot": "src",
    "compilerOptions": {
        "builder": "swc",
        "tsConfigPath": "./tsconfig.nest.json",
        "deleteOutDir": true,
        "assets": [
            {
                "include": "features/agent/*.txt",
                "outDir": "dist"
            }
        ]
    }
}
