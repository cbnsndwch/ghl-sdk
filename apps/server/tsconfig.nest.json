{
    "extends": "./tsconfig.node.json",
    "compilerOptions": {
        "incremental": false,
        "rootDir": "src",
        "outDir": "dist",
        "paths": {
            "src/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "src",
    ],
    "exclude": [
        "node_modules",
        "test",
        "dist",
        "app",
        "**/*spec.ts",
        "src/templates"
    ]
}