{
    "name": "@cbnsndwch/ghl-sdk-webhooks",
    "description": "Webhook utilities for GHL SDK",
    "version": "0.5.2",
    "type": "module",
    "license": "MIT",
    "author": {
        "name": "Sergio Leon",
        "url": "https://www.cbnsndwch.io"
    },
    "keywords": [
        "ghl",
        "highlevel",
        "cbnsndwch"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/cbnsndwch/ghl-sdk.git",
        "directory": "libs/sdk-webhooks"
    },
    "scripts": {
        "clean": "rimraf dist",
        "prebuild": "pnpm clean",
        "build": "tsup",
        "format": "oxfmt --write src",
        "lint": "oxlint ./src",
        "lint:fix": "oxlint ./src --fix"
    },
    "dependencies": {
        "@cbnsndwch/ghl-sdk-storage": "workspace:*"
    },
    "devDependencies": {
        "@types/express": "catalog:",
        "@types/node": "catalog:",
        "express": "catalog:",
        "rimraf": "catalog:",
        "tsup": "catalog:",
        "typescript": "catalog:"
    },
    "peerDependencies": {
        "@cbnsndwch/ghl-sdk-storage": "workspace:*"
    },
    "peerDependenciesMeta": {
        "express": {
            "optional": true
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./adapters/express": {
            "types": "./dist/adapters/express.d.ts",
            "default": "./dist/adapters/express.js"
        }
    },
    "engines": {
        "node": ">=22"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "packageManager": "pnpm@10.33.0"
}
