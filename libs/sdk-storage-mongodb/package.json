{
    "name": "@cbnsndwch/ghl-sdk-storage-mongodb",
    "description": "MongoDB storage adapter for GHL SDK",
    "version": "0.5.2",
    "type": "module",
    "license": "MIT",
    "author": {
        "name": "Sergio Leon",
        "url": "https://www.cbnsndwch.io"
    },
    "keywords": [
        "ghl",
        "highlevel",
        "cbnsndwch"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/cbnsndwch/ghl-sdk.git",
        "directory": "libs/sdk-storage-mongodb"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "scripts": {
        "clean": "rimraf dist",
        "prebuild": "pnpm clean",
        "build": "tsup",
        "format": "oxfmt --write src",
        "lint": "oxlint ./src",
        "lint:fix": "oxlint ./src --fix"
    },
    "dependencies": {
        "@cbnsndwch/ghl-sdk-storage": "workspace:*",
        "mongodb": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "rimraf": "catalog:",
        "tsup": "catalog:",
        "typescript": "catalog:"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "engines": {
        "node": ">=22"
    },
    "packageManager": "pnpm@10.33.0"
}
